# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/creator_bio_hub"

# ─── Twitch Extension ─────────────────────────────────────────────────────────
# Copy the base64 secret from: Twitch Dev Console > Extensions > Settings > Extension Secret
TWITCH_EXT_SECRET="your_base64_encoded_secret_here"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SUCCESS_URL="http://localhost:8080?upgrade=success"
STRIPE_CANCEL_URL="http://localhost:8080?upgrade=cancel"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
